#!/bin/rc
# claudebox PROJECTDIR -- run claude9fs+claudetalk in a
# restricted namespace where /mnt/term is not visible and
# /n/proj is the designated working tree.
#
# This is a namespace sandbox, not a permission sandbox.
# If you are hostowner, the model can still write to system
# trees that are bound into the box (/bin, /lib, etc.).
# What it CANNOT do is see or touch:
#   - /mnt/term (your drawterm host filesystem)
#   - /mnt/wsys, /mnt/plumb, or other parent /mnt entries
#   - anything under /usr/$user except the project dir
# The project directory appears as /n/proj inside the box.

rfork ne

if(! ~ $#* 1){
	echo usage: claudebox projectdir >[1=2]
	exit usage
}
proj=`{cleanname -d `{pwd} $1}
if(! test -d $proj){
	echo $proj: not a directory >[1=2]
	exit nodir
}

ROOT=/n/claudebox.$pid

ramfs -m $ROOT

if(! test -e /mnt/web/clone)
	webfs

# Create mountpoints.  $ROOT is a writable ramfs.
mkdir -p $ROOT/^(bin lib $cputype fd dev proc net srv mnt \
	env tmp n/proj usr/$user)

# System trees -- bound directly.  No read-only enforcement;
# that would require srvfs -R which deadlocks (see NOTES.md).
# The namespace restriction is still valuable: /mnt/term and
# the user's home tree are not exposed.
bind -a /$cputype/bin		$ROOT/bin
bind -a /rc/bin			$ROOT/bin
bind -a $home/bin/$cputype	$ROOT/bin >[2]/dev/null
bind -a $home/bin/rc		$ROOT/bin >[2]/dev/null
bind -a /$cputype		$ROOT/$cputype
bind -a /lib			$ROOT/lib

# Kernel devices and IPC -- not disk, safe to bind directly.
for(d in fd dev proc net)
	bind -a /$d $ROOT/$d

# /srv with create so claude9fs can post its channel.
bind -ac /srv $ROOT/srv

# Private /mnt -- this is the key security measure.
# Only web, factotum, webcookies are brought in.
# /mnt/term (drawterm host fs) is NOT exposed.
ramfs -m $ROOT/mnt
for(d in web factotum webcookies){
	if(test -e /mnt/$d){
		mkdir -p $ROOT/mnt/$d
		bind -a /mnt/$d $ROOT/mnt/$d
	}
}
mkdir -p $ROOT/mnt/claude

# Env writable for child processes.
bind -c '#e' $ROOT/env

# The project directory -- the intended working tree.
bind -c $proj $ROOT/n/proj

# Pivot.
bind -b $ROOT /
cd /n/proj

# Run.
srvname=claude.$pid
claude9fs -s $srvname
claudetalk

# Cleanup.
unmount /mnt/claude >[2]/dev/null
rm -f /srv/$srvname
