+static int
+fmtjstr(Fmt *f, char *s)
+{
+	Rune r;
+	int n;
+
+	fmtrune(f, '"');
+	while(*s){
+		n = chartorune(&r, s);
+		if(n <= 0)
+			break;
+		switch(r){
+		case '"':  fmtprint(f, "\\\""); break;
+		case '\\': fmtprint(f, "\\\\"); break;
+		case '\b': fmtprint(f, "\\b"); break;
+		case '\f': fmtprint(f, "\\f"); break;
+		case '\n': fmtprint(f, "\\n"); break;
+		case '\r': fmtprint(f, "\\r"); break;
+		case '\t': fmtprint(f, "\\t"); break;
+		default:
+			if(r < 0x20)
+				fmtprint(f, "\\u%04x", (uint)r);
+			else
+				fmtrune(f, r);
+			break;
+		}
+		s += n;
+	}
+	return fmtrune(f, '"');
 }
 
