+static int
+parseu4(char *p, Rune *rp)
+{
+	int i, h;
+	Rune r;
+
+	r = 0;
+	for(i = 0; i < 4; i++){
+		if(p[i] == '\0')
+			return -1;
+		h = hexval(p[i]);
+		if(h < 0)
+			return -1;
+		r = (r << 4) | h;
+	}
+	*rp = r;
+	return 0;
+}
