#!/bin/rc
# claudetalk - interactive Claude chat via claude9fs
#
# usage: claudetalk [-d] [-a session] [-l convfile]
#   -a N      attach to existing session N (instead of cloning)
#   -d        detach on exit: leave session alive for later -a
#   -l file   load conversation from file on startup

rfork e

attach=()
detach=0
loadfile=()
flagfmt='a:attach,d,l:loadfile'
args=''
if(! ifs=() eval `{aux/getflags $*}){
	echo 'usage: claudetalk [-d] [-a session] [-l convfile]' >[1=2]
	exit usage
}

mnt=/mnt/claude
if(! test -f $mnt/clone){
	echo 'claude9fs not mounted on '$mnt >[1=2]
	exit 'no fs'
}

# Memory store check: beads gives Claude persistent, structured
# memory across sessions.  If $beads is set we use that path,
# otherwise default to /n/beads.  Absence is non-fatal; tools
# that touch the store will just see ENOENT.
if(~ $#beads 0)
	beads=/n/beads
if(! test -d $beads/by-id){
	echo 'memory: '$beads' not mounted (beadsfs disabled)' >[1=2]
	echo 'hint: beadsfs -s beads -m '$beads' <store>' >[1=2]
}
if not
	echo 'memory: '$beads >[1=2]

if(~ $#attach 0){
	n=`{cat $mnt/clone}
	if(~ $#n 0){
		echo 'failed to allocate session' >[1=2]
		exit 'clone failed'
	}
}
if not {
	n=$attach
	if(! test -d $mnt/$n){
		echo 'session '$n' does not exist' >[1=2]
		exit 'no session'
	}
}
sess=$mnt/$n

fn teardown {
	if(! ~ $detach 1)
		echo hangup > $sess/ctl >[2]/dev/null
}

fn sigexit {
	teardown
}

curmodel=`{cat $sess/model}
curtokens=`{cat $sess/tokens}
echo 'claude9 session '$n' - '$curmodel >[1=2]
echo 'commands: /sessions /models /model [name] /tokens [n] /clear /detach /help /quit' >[1=2]
echo 'type message, end with ^D to send, DEL to interrupt' >[1=2]
if(~ $detach 1)
	echo 'detach mode: session will persist on exit (reattach with -a '$n')' >[1=2]
echo '' >[1=2]

# load conversation from file if requested
if(! ~ $#loadfile 0){
	echo 'load '$loadfile > $sess/ctl
	echo 'loaded '$loadfile >[1=2]
}

fn docmd {
	cmd=$1
	if(~ $cmd /clear){
		echo clear > $sess/ctl
		echo 'cleared' >[1=2]
	}
	if not if(~ $cmd /detach){
		detach=1
		echo 'session '$n' will persist on exit (reattach with: claudetalk -a '$n')' >[1=2]
	}
	if not if(~ $cmd /sessions){
		echo 'sessions:' >[1=2]
		for(d in $mnt/[0-9]*){
			sid=`{basename $d}
			smod=`{cat $d/model}
			smsgs=`{cat $d/ctl | grep '^messages' | sed 's/messages //'}
			if(~ $sid $n)
				echo '  '$sid' '$smod' ('$smsgs' msgs) *' >[1=2]
			if not
				echo '  '$sid' '$smod' ('$smsgs' msgs)' >[1=2]
		}
	}
	if not if(~ $cmd /models){
		echo 'fetching models...' >[1=2]
		cat $mnt/models >[1=2]
	}
	if not if(~ $cmd /model){
		if(~ $#* 1)
			echo 'model: '^`{cat $sess/model} >[1=2]
		if not {
			shift
			echo -n $"* > $sess/model
			echo 'model: '^`{cat $sess/model} >[1=2]
		}
	}
	if not if(~ $cmd /tokens){
		if(~ $#* 1)
			echo 'tokens: '^`{cat $sess/tokens} >[1=2]
		if not {
			shift
			echo -n $"* > $sess/tokens
			echo 'tokens: '^`{cat $sess/tokens} >[1=2]
		}
	}
	if not if(~ $cmd /status){
		cat $sess/ctl >[1=2]
	}
	if not if(~ $cmd /usage){
		cat $sess/usage >[1=2]
	}
	if not if(~ $cmd /help){
		echo 'commands:' >[1=2]
		echo '  /sessions      list live sessions' >[1=2]
		echo '  /models        list available models' >[1=2]
		echo '  /model         show current model' >[1=2]
		echo '  /model <name>  switch model' >[1=2]
		echo '  /tokens        show max output tokens' >[1=2]
		echo '  /tokens <n>    set max output tokens' >[1=2]
		echo '  /clear         clear conversation' >[1=2]
		echo '  /status        show session info' >[1=2]
		echo '  /usage         show token usage' >[1=2]
		echo '  /save <path>   save conversation' >[1=2]
		echo '  /load <path>   load conversation' >[1=2]
		echo '  /detach        keep session alive on exit' >[1=2]
		echo '  /quit          exit' >[1=2]
	}
	if not if(~ $cmd /save){
		shift
		if(! ~ $#* 0){
			echo 'save '$"* > $sess/ctl
			echo 'saved to '$"* >[1=2]
		}
		if not
			echo 'usage: /save <path>' >[1=2]
	}
	if not if(~ $cmd /load){
		shift
		if(! ~ $#* 0){
			echo 'load '$"* > $sess/ctl
			echo 'loaded '$"* >[1=2]
		}
		if not
			echo 'usage: /load <path>' >[1=2]
	}
	if not {
		echo 'unknown command: '$cmd >[1=2]
	}
}

# Read user input preserving newlines and whitespace.
# cat reads until EOF (^D); we capture into a temp file
# so that blank lines and indentation survive intact.
# Returns the content via $msg (tokenized) for command
# detection, and writes the raw text to $msgfile.
msgfile=/tmp/claudetalk.$pid
fn cleanup {
	rm -f $msgfile
}

# On Plan 9, the interrupt note (sent by the DEL key) maps to
# sigint.  Without an explicit handler rc just keeps looping
# because the inner subprocess absorbs the note.  Define
# handlers that tear down the session and exit.
fn sigexit {
	teardown
	cleanup
}
fn sigint {
	teardown
	cleanup
	exit interrupt
}

while(){
	curmodel=`{cat $sess/model}
	curtokens=`{cat $sess/tokens}
	prompt=$curmodel/$curtokens'> '
	echo -n $prompt >[1=2]

	cat > $msgfile
	if(! test -s $msgfile)
		break

	# read first line for command detection
	first=`{sed 1q $msgfile}
	if(~ $#first 0)
		break
	cmd=$first(1)

	if(~ $cmd /quit /exit)
		break

	if(~ $cmd /*)
		docmd $first
	if not {
		# Start the streaming reader first so it is blocked in
		# open() before we write the prompt.  The read on stream
		# waits for the next round to begin, streams text as it
		# arrives, then EOFs when the round is complete.
		cat $sess/stream &
		cpid=$apid
		if(cat $msgfile > $sess/prompt){
			wait $cpid
			echo '' >[1=2]
			cat $sess/usage >[1=2]
		}
		if not {
			wait $cpid
			echo 'error:' >[1=2]
			cat $sess/error >[1=2]
		}
		echo '' >[1=2]
	}
}

cleanup
teardown
