#!/bin/rc
# claudetalk - interactive Claude chat via claude9fs
#
# Bootstraps the full environment: starts a sub-agent claude9fs
# (for sub-agent support), then the main claude9fs on top, so
# the main server's namespace includes the sub-agent mount.
# The servers persist across runs and are reused on the next
# start (rm /srv/claude /srv/claudesub to stop them); on exit
# the session is hung up unless -d.
#
# usage: claudetalk [-d] [-g] [-a session] [-M model] [-P provider] [-t maxtokens] [-K skillsdir] [-n namepath]
#   -a name       attach to existing session (skip server startup)
#   -d            detach on exit: leave the session alive
#   -g            also pop up a claudegraph window on the session graph
#   -M model      default model for claude9fs
#   -P provider   default provider for claude9fs (anthropic or openai;
#                 needs the matching API key in the environment:
#                 $ANTHROPIC_API_KEY or $OPENAI_API_KEY)
#   -t maxtokens  default max tokens for claude9fs
#   -K skillsdir  skills directory for claude9fs
#   -n namepath   name server path for claude9fs

rfork e

flagfmt='a:attach session,d:detach,g:graph,M:model name,P:provider name,t:maxtokens n,K:skills dir,n:namepath path'
if(! ifs=() eval `{aux/getflags $*}){
	echo 'usage: claudetalk [-d] [-g] [-a session] [-M model] [-P provider] [-t maxtokens] [-K skillsdir] [-n namepath]' >[1=2]
	exit usage
}

mnt=/mnt/claude
submnt=/mnt/claudesub
srvname=claude
subsrvname=claudesub

# Track whether we started the servers so we know to clean up.
started_sub=0
started_main=0

# Build the common flags to pass through to claude9fs.
fsflags=()
# Default skills directory is $home/lib/claude9/skills unless
# overridden with -K.
if(~ $#skills 0)
	skills=$home/lib/claude9/skills
if(! ~ $#model 0)
	fsflags=($fsflags -M $model)
if(! ~ $#provider 0)
	fsflags=($fsflags -P $provider)
if(! ~ $#maxtokens 0)
	fsflags=($fsflags -t $maxtokens)
if(! ~ $#skills 0)
	if(test -d $skills)
		fsflags=($fsflags -K $skills)
if(! ~ $#namepath 0)
	fsflags=($fsflags -n $namepath)

fn startsub {
	if(test -f /srv/$subsrvname){
		# Sub-agent server already posted; just mount it.
		if(! test -f $submnt/clone)
			mount -c /srv/$subsrvname $submnt
		echo 'sub-agent: '$submnt' (already running)' >[1=2]
	}
	if not {
		claude9fs -s $subsrvname -m $submnt $fsflags
		started_sub=1
		echo 'sub-agent: '$submnt >[1=2]
	}
}

fn startmain {
	if(test -f /srv/$srvname){
		# Main server already posted; just mount it.
		if(! test -f $mnt/clone)
			mount -c /srv/$srvname $mnt
		echo 'claude9fs: '$mnt' (already running)' >[1=2]
	}
	if not {
		claude9fs -s $srvname -m $mnt $fsflags
		started_main=1
		echo 'claude9fs: '$mnt >[1=2]
	}
}

fn stopservers {
	# Only tear down servers we started.
	if(~ $started_main 1){
		unmount $mnt >[2]/dev/null
		rm -f /srv/$srvname >[2]/dev/null
	}
	if(~ $started_sub 1){
		unmount $submnt >[2]/dev/null
		rm -f /srv/$subsrvname >[2]/dev/null
	}
}

# If attaching, assume servers are already running.
# Otherwise, bootstrap: sub-agent first, then main.
if(~ $#attach 0){
	startsub
	startmain
	if(! test -f $mnt/clone){
		echo 'claude9fs failed to start on '$mnt >[1=2]
		stopservers
		exit 'no fs'
	}
}
if not {
	# Attach mode: servers must already exist.
	if(test -f /srv/$subsrvname){
		if(! test -f $submnt/clone)
			mount -c /srv/$subsrvname $submnt
	}
	if(test -f /srv/$srvname){
		if(! test -f $mnt/clone)
			mount -c /srv/$srvname $mnt
	}
	if(! test -f $mnt/clone){
		echo 'claude9fs not mounted on '$mnt >[1=2]
		exit 'no fs'
	}
}

if(~ $graph 1){
	# Pop up in a fresh rio window rather than forking in place:
	# claudegraph draws over whatever window it runs in, and this
	# one is busy being the chat terminal.  A window created via
	# rio(1)'s "window" gets its own, unrelated namespace group,
	# so claudegraph mounting /mnt/claude here first would not
	# help it anyway; claudegraph's own /srv fallback (see
	# automount() in claudegraph.c) is what makes it work there.
	window claudegraph $mnt $submnt &
	echo 'claudegraph: opened in a new window' >[1=2]
}

if(~ $#attach 0){
	n=`{cat $mnt/clone}
	if(~ $#n 0){
		echo 'failed to allocate session' >[1=2]
		stopservers
		exit 'clone failed'
	}
}
if not {
	n=$attach
	if(! test -d $mnt/$n){
		echo 'session '$n' does not exist' >[1=2]
		exit 'no session'
	}
}
sess=$mnt/$n

fn teardown {
	if(! ~ $detach 1){
		echo hangup > $sess/ctl >[2]/dev/null
	}
}

curmodel=`{cat $sess/model}
curtokens=`{cat $sess/tokens}
echo 'claude9 session '$n' - '$curmodel >[1=2]
echo 'commands: /sessions /models /model [name] /provider [name] /baseurl [url] /tokens [n] /thinking [n] /clear /compact [n] /status /usage /autocontinue [n] /noautocontinue /reloadskills /graph /detach /help /quit' >[1=2]
echo 'type message, end with ^D to send, DEL to interrupt' >[1=2]
if(~ $detach 1)
	echo 'detach mode: session will persist on exit (reattach with -a '$n')' >[1=2]
echo '' >[1=2]

fn setget {
	file=$1
	label=$2
	shift 2
	if(~ $#* 0)
		echo $label': '^`{cat $file} >[1=2]
	if not {
		echo -n $"* > $file
		echo $label': '^`{cat $file} >[1=2]
	}
}

fn docmd {
	cmd=$1
	if(~ $cmd /clear){
		echo clear > $sess/ctl
		echo 'cleared' >[1=2]
	}
	if not if(~ $cmd /detach){
		detach=1
		echo 'session '$n' will persist on exit (reattach with: claudetalk -a '$n')' >[1=2]
	}
	if not if(~ $cmd /compact){
		shift
		# Show size before and after so the user sees the effect.
		before=`{awk '/^exchanges/{print $2}' $sess/ctl}
		if(~ $#* 0)
			echo 'compact' > $sess/ctl
		if not
			echo 'compact '$1 > $sess/ctl
		after=`{awk '/^exchanges/{print $2}' $sess/ctl}
		bytes=`{awk '/^bytes/{print $2}' $sess/ctl}
		echo 'compacted: '$before' -> '$after' exchanges ('$bytes' input bytes)' >[1=2]
	}
	if not if(~ $cmd /sessions){
		# Sessions are the directories under $mnt; the root
		# also holds plain files (clone, models, graph, ...).
		echo 'sessions:' >[1=2]
		for(sid in `{ls -p $mnt}){
			d=$mnt/$sid
			if(test -d $d){
				smod=`{cat $d/model}
				smsgs=`{awk '/^messages/{print $2}' $d/ctl}
				if(~ $sid $n)
					echo '  '$sid' '$smod' ('$smsgs' msgs) *' >[1=2]
				if not
					echo '  '$sid' '$smod' ('$smsgs' msgs)' >[1=2]
			}
		}
	}
	if not if(~ $cmd /models){
		shift
		# The root models file lists every provider that has an
		# API key configured, not just the one this session is
		# using -- with both keys set that is two providers'
		# worth of ids in one blob, and OpenAI's real endpoint
		# in particular returns far more than just chat models
		# (embeddings, whisper, moderation, fine-tunes...), so
		# the unfiltered dump is noisy once you've actually
		# picked a provider.  Default to just this session's
		# current provider's section; "/models all" (or naming
		# the other provider explicitly) still shows everything.
		curprov=`{cat $sess/provider >[2]/dev/null}
		if(~ $#curprov 0)
			curprov=anthropic
		which=$curprov
		if(! ~ $#* 0)
			which=$1
		echo 'fetching models...' >[1=2]
		if(~ $which all){
			cat $mnt/models >[1=2]
		}
		if not {
			awk -v 'want='^$"which '
				$0 == want ":" { show = 1; found = 1; next }
				/:$/ { show = 0 }
				show { print; printed = 1 }
				END {
					if (!found)
						print "no models found for provider " want " (check spelling/API key; try \"/models all\")"
					else if (!printed)
						print "(no models listed for " want ")"
				}
			' $mnt/models >[1=2]
		}
	}
	if not if(~ $cmd /model){
		shift
		setget $sess/model model $*
	}
	if not if(~ $cmd /provider){
		shift
		setget $sess/provider provider $*
		if(! ~ $#* 0){
			# The model name does not follow the provider;
			# an anthropic model sent to openai (or vice
			# versa) fails every request.  Remind the user.
			echo 'model is '^`{cat $sess/model}^' - you probably want /model (see /models)' >[1=2]
		}
	}
	if not if(~ $cmd /baseurl){
		shift
		setget $sess/baseurl baseurl $*
	}
	if not if(~ $cmd /tokens){
		shift
		setget $sess/tokens tokens $*
	}
	if not if(~ $cmd /thinking){
		shift
		setget $sess/thinking thinking $*
	}
	if not if(~ $cmd /status){
		cat $sess/ctl >[1=2]
	}
	if not if(~ $cmd /usage){
		cat $sess/usage >[1=2]
	}
	if not if(~ $cmd /help){
		echo 'commands:' >[1=2]
		echo '  /sessions      list live sessions' >[1=2]
		echo '  /models        list models for the current provider' >[1=2]
		echo '  /models <p>    list models for provider <p> (anthropic or openai)' >[1=2]
		echo '  /models all    list models for every provider with a key configured' >[1=2]
		echo '  /model         show current model' >[1=2]
		echo '  /model <name>  switch model' >[1=2]
		echo '  /provider      show current provider' >[1=2]
		echo '  /provider <p>  switch provider: anthropic or openai (needs its API key;' >[1=2]
		echo '                 switch /model too - model names are per-provider)' >[1=2]
		echo '  /baseurl       show endpoint URL override' >[1=2]
		echo '  /baseurl <url> point an openai-compatible server (llama.cpp, vllm, ...)' >[1=2]
		echo '  /baseurl -     clear the override (back to provider default)' >[1=2]
		echo '  /tokens        show max output tokens' >[1=2]
		echo '  /tokens <n>    set max output tokens' >[1=2]
		echo '  /thinking      show extended thinking setting' >[1=2]
		echo '  /thinking <n>  budget mode, n tokens (opus etc.; 0 = off, min 1024)' >[1=2]
		echo '  /thinking adaptive [effort]  adaptive mode (fable; effort e.g. low/medium/high)' >[1=2]
		echo '  /clear         clear conversation' >[1=2]
		echo '  /compact [n]   drop old exchanges, keep n recent (default 4)' >[1=2]
		echo '  /status        show session info' >[1=2]
		echo '  /usage         show token usage' >[1=2]
		echo '  /autocontinue [n]  auto-continue on max_tokens (default 3)' >[1=2]
		echo '  /noautocontinue   disable auto-continue' >[1=2]
		echo '  /reloadskills  re-read the skills directory (all sessions)' >[1=2]
		echo '  /graph         open a claudegraph window on all live sessions' >[1=2]
		echo '  /detach        keep session alive on exit' >[1=2]
		echo '  /quit          exit' >[1=2]
	}
	if not if(~ $cmd /autocontinue /ac){
		shift
		if(~ $#* 0)
			echo 'autocontinue' > $sess/ctl
		if not
			echo 'autocontinue '$1 > $sess/ctl
		ac=`{awk '/^autocontinue/{print $2}' $sess/ctl}
		echo 'autocontinue: '$ac >[1=2]
	}
	if not if(~ $cmd /noautocontinue /noac){
		echo 'noautocontinue' > $sess/ctl
		echo 'autocontinue: 0' >[1=2]
	}
	if not if(~ $cmd /reloadskills){
		echo reloadskills > $sess/ctl
		echo 'skills reloaded' >[1=2]
	}
	if not if(~ $cmd /graph){
		window claudegraph $mnt $submnt &
		echo 'claudegraph: opened in a new window' >[1=2]
	}
	if not {
		echo 'unknown command: '$cmd >[1=2]
	}
}

# Read user input preserving newlines and whitespace.
msgfile=/tmp/claudetalk.$pid
fn cleanup {
	rm -f $msgfile
}

fn sigexit {
	teardown
	cleanup
}
fn sigint {
	teardown
	cleanup
	exit interrupt
}

while(){
	curmodel=`{cat $sess/model}
	curtokens=`{cat $sess/tokens}
	curprov=`{cat $sess/provider >[2]/dev/null}
	# Old servers have no provider file; treat that as the
	# default (an empty list would also poison the prompt
	# concatenation below - rc lists absorb adjacent words).
	if(~ $#curprov 0)
		curprov=anthropic
	# Show the provider in the prompt only when it is not the
	# house default; dial-string style, provider!model/tokens.
	if(~ $curprov anthropic)
		prompt=$curmodel/$curtokens'> '
	if not
		prompt=$curprov'!'$curmodel/$curtokens'> '
	echo -n $prompt >[1=2]

	cat > $msgfile
	if(! test -s $msgfile)
		break

	# read first line for command detection
	first=`{sed 1q $msgfile}
	if(~ $#first 0)
		break
	cmd=$first(1)

	if(~ $cmd /quit /exit)
		break

	if(~ $cmd /*)
		docmd $first
	if not {
		# Start the streaming reader first so it is blocked in
		# open() before we write the prompt.
		cat $sess/stream &
		cpid=$apid
		if(cat $msgfile > $sess/prompt){
			wait $cpid
			echo '' >[1=2]
			cat $sess/usage >[1=2]
		}
		if not {
			# The prompt write can fail before a round ever
			# starts (e.g. 'session busy'), leaving the
			# stream reader latched on an idle session,
			# waiting for a round that will never come.
			# Kill it so wait does not hang; the resulting
			# Tflush is handled cleanly by claude9fs.
			# Order matters: rc opens the redirections
			# left to right, and note may already be
			# gone (the cat process can exit on its own,
			# e.g. via the Tflush this triggers, before
			# we get here) -- an open failure on the
			# still-pending ">" is reported to whatever
			# fd2 is at that point in the parse.  Put the
			# >[2]/dev/null FIRST so fd2 is already
			# silenced when the /proc/$cpid/note open is
			# attempted, instead of leaking "can't
			# create: .../note: file does not exist" to
			# the real terminal despite the redirection.
			echo kill >[2]/dev/null > /proc/$cpid/note
			wait $cpid
			echo 'error:' >[1=2]
			cat $sess/error >[1=2]
		}
		echo '' >[1=2]
	}
}

cleanup
teardown
